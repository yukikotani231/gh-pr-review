#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

staged_go_files=$(mktemp)
unstaged_go_files=$(mktemp)
staged_go_lines=$(mktemp)
unstaged_go_lines=$(mktemp)
trap 'rm -f "$staged_go_files" "$unstaged_go_files" "$staged_go_lines" "$unstaged_go_lines"' EXIT INT TERM HUP

git diff --cached --name-only -z --diff-filter=ACMR -- '*.go' >"$staged_go_files"
if [ -s "$staged_go_files" ]; then
  git diff --name-only -z -- '*.go' >"$unstaged_go_files"
  tr '\0' '\n' <"$staged_go_files" >"$staged_go_lines"
  tr '\0' '\n' <"$unstaged_go_files" >"$unstaged_go_lines"
  overlapping_go_files=$(grep -Fxf "$staged_go_lines" "$unstaged_go_lines" || true)
  if [ -n "$overlapping_go_files" ]; then
    echo "Refusing to run gofmt because these staged Go files also have unstaged changes:" >&2
    printf '%s\n' "$overlapping_go_files" >&2
    exit 1
  fi

  echo "Running gofmt on staged Go files..."
  xargs -0 -n 1 gofmt -w <"$staged_go_files"
  xargs -0 -n 1 git add -- <"$staged_go_files"
fi

echo "Running go test..."
go test -race -count=1 ./...

echo "Running go vet..."
go vet ./...

if command -v golangci-lint >/dev/null 2>&1; then
  echo "Running golangci-lint..."
  golangci-lint run ./...
else
  echo "Skipping golangci-lint (command not found)" >&2
fi
